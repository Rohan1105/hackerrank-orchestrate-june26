GEMINI_API_KEY=your-gemini-key-here
# Optional override, defaults to gemini-flash-latest. Pinned versions
# (gemini-2.5-flash, gemini-2.5-flash-lite, gemini-2.0-flash, gemini-2.0-flash-lite)
# share a combined 20-requests/day free-tier cap per project; the gemini-*-latest
# aliases are tracked under a separate quota bucket and had headroom when this was
# written. If you hit 429 RESOURCE_EXHAUSTED, try a different alias or enable billing.
# GEMINI_MODEL=gemini-flash-latest
